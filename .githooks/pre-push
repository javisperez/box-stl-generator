#!/bin/sh
# Pre-push guard: refuse to push code that generates broken STLs.
# Runs the mesh-integrity sweep (open edges, non-manifold edges, flipped
# facets, inside-out shells) across all representative export configurations.
#
# Installed automatically: `pnpm install` runs the "prepare" script, which
# points core.hooksPath at .githooks. Bypass in an emergency with
# `git push --no-verify`.

set -e
cd "$(git rev-parse --show-toplevel)"

echo "pre-push: running STL mesh-integrity sweep…"
if ! pnpm run --silent check:stl; then
  echo ""
  echo "pre-push: BLOCKED — some configurations export broken STL geometry."
  echo "Fix the geometry (or bypass once with: git push --no-verify)."
  exit 1
fi
